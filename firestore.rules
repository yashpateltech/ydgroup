rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /blogs/{blogId} {
      // Allow public to read published blogs
      allow read: if resource.data.status == 'published';
      
      // Allow the admin to manage blogs
      // NOTE: In a real production app, you should use Firebase Auth
      // and check request.auth.uid here. For this demo with static 
      // credentials, we allow writes.
      allow write: if true;
    }

    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if true; // In prod, restricted to admin
    }

    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if true; // In prod, restricted to admin
    }
  }
}
